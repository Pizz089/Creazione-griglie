<Window x:Class="DirectXEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        Title="DirectX .X Editor 3D" Height="750" Width="1100"
        WindowState="Maximized" 
        Background="{DynamicResource BgFinestra}">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource BgCard}" Margin="10,10,10,0" Padding="6" CornerRadius="8" Effect="{StaticResource OmbraCard}">
            <StackPanel Orientation="Horizontal">

                <Button Click="BtnCarica_Click" Style="{StaticResource TopMenuButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📂" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Carica" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnSalva" Click="BtnSalva_Click" Style="{StaticResource TopMenuButtonStyle}" Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Salva" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Button Click="BtnSalvaConNome_Click" Style="{StaticResource TopMenuButtonStyle}" Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Salva con nome" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Button Click="BtnGestioneStili_Click" Style="{StaticResource TopMenuButtonStyle}" Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎨" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Gestione Stili" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Border Width="1" Background="{DynamicResource ColoreBordoCard}" Margin="15,4" CornerRadius="1"/>

                <Button Click="BtnHome_Click" Style="{StaticResource TopMenuButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏠" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Ripristina Vista" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180" MaxWidth="450"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="280" MinWidth="220" MaxWidth="500"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource BgCard}" Margin="10,0,4,10" CornerRadius="8" Effect="{StaticResource OmbraCard}">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Top" Text="Gerarchia Elementi" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TestoPrincipale}" Margin="0,0,0,10" TextAlignment="Center"/>

                    <Border DockPanel.Dock="Bottom" Background="{DynamicResource BgFinestra}" CornerRadius="8" Padding="12" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="Comandi 3D" FontWeight="Bold" Foreground="{DynamicResource TestoPrincipale}" FontSize="12" Margin="0,0,0,8" HorizontalAlignment="Center"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Clic Sinistro:" FontWeight="SemiBold" Foreground="{DynamicResource TestoPrincipale}" FontSize="11" Margin="0,2,8,2" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Seleziona" Foreground="{DynamicResource TestoSecondario}" FontSize="11" Margin="0,2,0,2" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Clic Destro:" FontWeight="SemiBold" Foreground="{DynamicResource TestoPrincipale}" FontSize="11" Margin="0,2,8,2" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Ruota vista" Foreground="{DynamicResource TestoSecondario}" FontSize="11" Margin="0,2,0,2" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Rotella (Premi):" FontWeight="SemiBold" Foreground="{DynamicResource TestoPrincipale}" FontSize="11" Margin="0,2,8,2" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Sposta (Pan)" Foreground="{DynamicResource TestoSecondario}" FontSize="11" Margin="0,2,0,2" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Rotella (Scorri):" FontWeight="SemiBold" Foreground="{DynamicResource TestoPrincipale}" FontSize="11" Margin="0,2,8,2" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="Zoom" Foreground="{DynamicResource TestoSecondario}" FontSize="11" Margin="0,2,0,2" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TreeView x:Name="treeComponenti" Background="Transparent" BorderThickness="0" 
                              Foreground="{DynamicResource TestoPrincipale}" SelectedItemChanged="TreeComponenti_SelectedItemChanged">
                        <TreeView.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF1E88E5" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF4F586D" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White" />
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="Padding" Value="4,2" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="IsExpanded" Value="True"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <Path x:Name="icon" Width="14" Height="14" Margin="0,0,6,0" Stretch="Uniform" Fill="#FF1E88E5"
                                          Data="M11 23.59v-10l-8.5-4.82v10l8.5 4.82Zm1-11.75 8.35-4.74-8.35-4.74-8.35 4.74 8.35 4.74Zm1 1.75v10l8.5-4.82v-10l-8.5 4.82Z"/>

                                    <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center" />
                                </StackPanel>
                                <HierarchicalDataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsGroup}" Value="True"/>
                                            <Condition Binding="{Binding OriginalXFileContent}" Value="{x:Null}"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="icon" Property="Data" Value="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z"/>
                                        <Setter TargetName="icon" Property="Fill" Value="#FFFFCC80"/>
                                    </MultiDataTrigger>
                                </HierarchicalDataTemplate.Triggers>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Style="{StaticResource ModernGridSplitterStyle}" Margin="0,0,0,10" VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

            <Border Grid.Column="2" Background="{DynamicResource BgFinestra}" Margin="4,0,4,10" CornerRadius="8" Effect="{StaticResource OmbraCard}">
                <helix:HelixViewport3D x:Name="viewPort" 
                                       ZoomExtentsWhenLoaded="True" 
                                       ShowCoordinateSystem="True" 
                                       CoordinateSystemLabelForeground="White"
                                       MouseLeftButtonDown="ViewPort_MouseLeftButtonDown">

                    <ModelVisual3D x:Name="luciContainer">
                        <ModelVisual3D.Content>
                            <Model3DGroup x:Name="luciGroup" />
                        </ModelVisual3D.Content>
                    </ModelVisual3D>

                    <ModelVisual3D x:Name="visualContainer">
                        <ModelVisual3D.Content>
                            <Model3DGroup x:Name="modelGroup" />
                        </ModelVisual3D.Content>
                    </ModelVisual3D>
                </helix:HelixViewport3D>
            </Border>

            <GridSplitter Grid.Column="3" Style="{StaticResource ModernGridSplitterStyle}" Margin="0,0,0,10" VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

            <Border Grid.Column="4" Background="{DynamicResource BgCard}" Margin="4,0,10,10" CornerRadius="8" Effect="{StaticResource OmbraCard}">
                <StackPanel x:Name="pannelloProprieta" Margin="15" IsEnabled="False">
                    <TextBlock Text="Proprietà Oggetto" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TestoPrincipale}" Margin="0,0,0,5" TextAlignment="Center"/>
                    <TextBlock x:Name="txtNomeSelezionato" Text="Nessuna selezione" Foreground="{DynamicResource ColorePrimario}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,20" TextAlignment="Center"/>

                    <CheckBox x:Name="chkApplicaATutti" Content="Applica a tutti gli oggetti con lo stesso aspetto" Style="{StaticResource ModernToggleStyle}" Margin="0,5,0,15" IsChecked="True" FontSize="14"/>

                    <TextBlock Text="Colore Avanzato" Foreground="{DynamicResource TestoSecondario}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <Border Background="{DynamicResource BgFinestra}" CornerRadius="6" Padding="8" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="rectColore" Background="White" CornerRadius="4" Margin="0,0,10,0" BorderBrush="{DynamicResource ColoreBordoCard}" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="RectColore_Click"/>
                            <Button Content="Modifica" Grid.Column="1" Style="{StaticResource BaseCardButtonStyle}" Background="{DynamicResource BgPulsante}" Foreground="{DynamicResource TestoPrincipale}" Padding="10,5" Click="RectColore_Click"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="Immagine Skin (Texture)" Foreground="{DynamicResource TestoSecondario}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <Border Background="{DynamicResource BgFinestra}" CornerRadius="6" Padding="8">
                        <StackPanel>
                            <TextBlock x:Name="txtTexturePath" Text="Nessuna" Foreground="{DynamicResource TestoPrincipale}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="Sfoglia..." Style="{StaticResource BaseCardButtonStyle}" Background="{DynamicResource BgPulsante}" Foreground="{DynamicResource TestoPrincipale}" Padding="10,8" Margin="0,0,5,0" Click="BtnSkin_Click"/>
                                <Button Content="Rimuovi" Grid.Column="1" Style="{StaticResource BaseCardButtonStyle}" Background="#FFD32F2F" Foreground="White" Padding="10,8" Margin="5,0,0,0" Click="BtnRemoveSkin_Click"/>
                            </Grid>

                            <TextBlock Text="Zoom Skin (Scala UV)" Foreground="{DynamicResource TestoSecondario}" Margin="0,0,0,5" FontWeight="SemiBold" FontSize="11"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="45"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="slZoomSkin" Style="{StaticResource ModernSliderStyle}" Minimum="0.01" Maximum="30" Value="1" TickFrequency="0.1" ValueChanged="SlZoomSkin_ValueChanged" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox x:Name="txtZoomSkin" Text="1.00" Style="{StaticResource ModernInputStyle}" Grid.Column="1" TextChanged="TxtZoomSkin_TextChanged"/>
                            </Grid>

                            <Button x:Name="btnAutoFit" Content="Adatta Automaticamente" Style="{StaticResource BaseCardButtonStyle}" Background="{DynamicResource ColoreSecondario}" Foreground="White" Padding="10,5" Margin="0,0,0,15" Click="BtnAutoFitSkin_Click"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="btnModificaFisica" Content="Modifica Dimensioni Fisiche" Style="{StaticResource BaseCardButtonStyle}" Click="BtnModificaFisica_Click" Margin="0,10,0,0" Height="30" FontWeight="Bold" Background="{DynamicResource ColoreSelezione}" Foreground="{DynamicResource TestoPrincipale}" BorderBrush="{x:Null}"/>

                    <TextBlock x:Name="txtStatus" Margin="0,30" TextWrapping="Wrap" Foreground="{DynamicResource ColoreIngressi}" FontWeight="SemiBold" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>