<Window x:Class="Creazione_griglie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:helix="http://helix-toolkit.org/wpf"
        Title="DirectX .X Editor 3D" Height="750" Width="1100"
        WindowState="Maximized" 
        WindowStyle="None" AllowsTransparency="True"
        Background="{DynamicResource BgFinestra}" Foreground="{DynamicResource TestoPrincipale}"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="32" Background="{DynamicResource BgCard}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0">
                <Path Data="{StaticResource IconDataOpen}" Stretch="Uniform" Width="14" Height="14" Margin="0,0,8,0" Fill="{DynamicResource ColorePrimario}"/>
                <TextBlock Text="DirectX .X Editor 3D" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TestoSecondario}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Style="{StaticResource MaterialIconButtonStyle}" Width="45" Height="32" Padding="0" shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="Minimize_Click">
                    <Path Data="{StaticResource IconDataMinimize}" Fill="{DynamicResource TestoSecondario}" Stretch="Uniform" Width="12" Height="12"/>
                </Button>
                <Button Style="{StaticResource MaterialIconButtonStyle}" Width="45" Height="32" Padding="0" shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="MaximizeRestore_Click">
                    <Path Data="{StaticResource IconDataMaximize}" Fill="{DynamicResource TestoSecondario}" Stretch="Uniform" Width="12" Height="12"/>
                </Button>
                <Button Width="45" Height="32" Padding="0" shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="Close_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialIconButtonStyle}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFE53935" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Data="{StaticResource IconDataClose}" Fill="{DynamicResource TestoSecondario}" Stretch="Uniform" Width="12" Height="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <DockPanel Grid.Row="1">
            <Border DockPanel.Dock="Top" Background="{DynamicResource BgCard}" Margin="10,10,10,0" Padding="6" CornerRadius="8" Effect="{StaticResource OmbraCard}">
                <StackPanel Orientation="Horizontal">

                    <Button Click="BtnGestioneStili_Click" Style="{StaticResource BaseCardButtonStyle}" Margin="4,0,0,0" Padding="15,8" Foreground="{DynamicResource TestoPrincipale}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconDataOpen}" Fill="{DynamicResource TestoPrincipale}" Stretch="Uniform" Margin="0,0,8,0" Width="16" Height="16"/>
                            <TextBlock Text="{DynamicResource StrStiliDef}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Click="BtnSalvaConNome_Click" Style="{StaticResource BaseCardButtonStyle}" Margin="4,0,0,0" Padding="15,8" Foreground="{DynamicResource TestoPrincipale}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconDataSave}" Fill="{DynamicResource TestoPrincipale}" Stretch="Uniform" Margin="0,0,8,0" Width="16" Height="16"/>
                            <TextBlock Text="{DynamicResource StrSalvaNome}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="{DynamicResource ColoreBordoCard}" Margin="15,4" CornerRadius="1"/>

                    <Button Click="BtnCarica_Click" Style="{StaticResource BaseCardButtonStyle}" Margin="4,0,0,0" Padding="15,8" Foreground="{DynamicResource TestoPrincipale}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconDataOpen}" Fill="{DynamicResource TestoPrincipale}" Stretch="Uniform" Margin="0,0,8,0" Width="16" Height="16"/>
                            <TextBlock Text="{DynamicResource StrCarica}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnSalva" Click="BtnSalva_Click" Style="{StaticResource BaseCardButtonStyle}" Margin="4,0,0,0" Padding="15,8" Foreground="{DynamicResource TestoPrincipale}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconDataSave}" Fill="{DynamicResource TestoPrincipale}" Stretch="Uniform" Margin="0,0,8,0" Width="16" Height="16"/>
                            <TextBlock Text="{DynamicResource StrSalva}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="{DynamicResource ColoreBordoCard}" Margin="15,4" CornerRadius="1"/>

                    <Button x:Name="btnUndo" Click="BtnUndo_Click" Style="{StaticResource BaseCardButtonStyle}" Margin="0,0,4,0" IsEnabled="False" Padding="15,8" Foreground="{DynamicResource TestoPrincipale}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconDataReset}" Fill="{DynamicResource TestoPrincipale}" Stretch="Uniform" Margin="0,0,8,0" Width="16" Height="16"/>
                            <TextBlock Text="{DynamicResource StrAnnulla}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Click="BtnHome_Click" Style="{StaticResource BaseCardButtonStyle}" Padding="15,8" Foreground="{DynamicResource TestoPrincipale}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconDataRestore}" Fill="{DynamicResource TestoPrincipale}" Stretch="Uniform" Margin="0,0,8,0" Width="16" Height="16"/>
                            <TextBlock Text="{DynamicResource StrRipristina}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Border>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" MinWidth="180" MaxWidth="450"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="280" MinWidth="220" MaxWidth="500"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource BgCard}" Margin="10,0,4,10" CornerRadius="8" Effect="{StaticResource OmbraCard}">
                    <DockPanel Margin="10">
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource StrGerarchia}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TestoPrincipale}" Margin="0,0,0,10" TextAlignment="Center"/>

                        <Border DockPanel.Dock="Bottom" Background="{DynamicResource BgFinestra}" CornerRadius="8" Padding="12" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource StrComandi}" FontWeight="Bold" Foreground="{DynamicResource TestoPrincipale}" FontSize="12" Margin="0,0,0,8" HorizontalAlignment="Center"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Clic Sx:" FontWeight="SemiBold" Foreground="{DynamicResource TestoPrincipale}" FontSize="11" Margin="0,2,8,2" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource StrSeleziona}" Foreground="{DynamicResource TestoSecondario}" FontSize="11" Margin="0,2,0,2" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Clic Dx:" FontWeight="SemiBold" Foreground="{DynamicResource TestoPrincipale}" FontSize="11" Margin="0,2,8,2" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{DynamicResource StrRuota}" Foreground="{DynamicResource TestoSecondario}" FontSize="11" Margin="0,2,0,2" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Middle:" FontWeight="SemiBold" Foreground="{DynamicResource TestoPrincipale}" FontSize="11" Margin="0,2,8,2" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{DynamicResource StrPan}" Foreground="{DynamicResource TestoSecondario}" FontSize="11" Margin="0,2,0,2" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Scroll:" FontWeight="SemiBold" Foreground="{DynamicResource TestoPrincipale}" FontSize="11" Margin="0,2,8,2" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{DynamicResource StrZoom}" Foreground="{DynamicResource TestoSecondario}" FontSize="11" Margin="0,2,0,2" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TreeView x:Name="treeComponenti" Background="Transparent" BorderThickness="0" 
                                  Foreground="{DynamicResource TestoPrincipale}" SelectedItemChanged="TreeComponenti_SelectedItemChanged">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="Padding" Value="4,2" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="IsExpanded" Value="True"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path x:Name="icon" Width="14" Height="14" Margin="0,0,6,0" Stretch="Uniform" Fill="{DynamicResource ColorePrimario}" Data="{StaticResource IconDataOpen}"/>
                                        <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <HierarchicalDataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsGroup}" Value="True"/>
                                                <Condition Binding="{Binding OriginalXFileContent}" Value="{x:Null}"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="icon" Property="Data" Value="{StaticResource IconDataOpen}"/>
                                            <Setter TargetName="icon" Property="Fill" Value="#FFFFCC80"/>
                                        </MultiDataTrigger>
                                    </HierarchicalDataTemplate.Triggers>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Style="{StaticResource ModernGridSplitterStyle}" Margin="0,0,0,10" VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

                <Border Grid.Column="2" Background="{DynamicResource BgFinestra}" Margin="4,0,4,10" CornerRadius="8" Effect="{StaticResource OmbraCard}">
                    <Grid>

                        <ScrollViewer x:Name="pannelloGalleria" VerticalScrollBarVisibility="Auto" Visibility="Visible">
                            <ItemsControl x:Name="listaGruppiGalleria">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="10,15,10,15">
                                            <Border Background="{DynamicResource ColorePrimario}" HorizontalAlignment="Left" Padding="15,6" CornerRadius="6" Margin="10,0,0,10">
                                                <TextBlock Text="{Binding NomeGruppo}" FontWeight="Bold" FontSize="16" Foreground="White"/>
                                            </Border>

                                            <ItemsControl ItemsSource="{Binding Elementi}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border x:Name="RootCard" Width="280" Height="280" Margin="10" Background="{DynamicResource BgCard}" CornerRadius="8" BorderBrush="{DynamicResource ColoreBordoCard}" BorderThickness="1">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="*"/>
                                                                </Grid.RowDefinitions>

                                                                <Border Background="{DynamicResource ColoreBordoCard}" CornerRadius="8,8,0,0" Padding="8">
                                                                    <TextBlock Text="{Binding Titolo}" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                                                                </Border>

                                                                <helix:HelixViewport3D Grid.Row="1" ZoomExtentsWhenLoaded="True" ShowCoordinateSystem="False" ShowViewCube="False" IsHitTestVisible="False">
                                                                    <helix:HelixViewport3D.Camera>
                                                                        <PerspectiveCamera Position="0,0,100" LookDirection="0,0,-100" UpDirection="0,1,0"/>
                                                                    </helix:HelixViewport3D.Camera>
                                                                    <ModelVisual3D>
                                                                        <ModelVisual3D.Content>
                                                                            <AmbientLight Color="White" />
                                                                        </ModelVisual3D.Content>
                                                                    </ModelVisual3D>
                                                                    <ModelVisual3D Content="{Binding Modello}" />
                                                                </helix:HelixViewport3D>

                                                                <Grid Grid.Row="1" Background="Transparent" x:Name="hoverGrid">
                                                                    <Button Content="{DynamicResource StrIngrandisci}" x:Name="btnIngrandisci" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="15,10" Click="BtnIngrandisci_Click" Tag="{Binding}" Style="{StaticResource BaseCardButtonStyle}" Background="{DynamicResource ColorePrimario}" Foreground="White" FontWeight="Bold" Opacity="0" Visibility="Hidden"/>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <Trigger SourceName="RootCard" Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="btnIngrandisci" Property="Opacity" Value="1"/>
                                                                <Setter TargetName="btnIngrandisci" Property="Visibility" Value="Visible"/>
                                                                <Setter TargetName="hoverGrid" Property="Background" Value="#60000000"/>
                                                            </Trigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Grid x:Name="pannelloMassimizzato" Visibility="Collapsed">
                            <helix:HelixViewport3D x:Name="viewPortMassimizzato" 
                                                   ZoomExtentsWhenLoaded="True" 
                                                   ShowCoordinateSystem="True" 
                                                   CoordinateSystemLabelForeground="White"
                                                   MouseLeftButtonDown="ViewPort_MouseLeftButtonDown">

                                <ModelVisual3D x:Name="luciContainer">
                                    <ModelVisual3D.Content>
                                        <Model3DGroup x:Name="luciGroup" />
                                    </ModelVisual3D.Content>
                                </ModelVisual3D>

                                <ModelVisual3D x:Name="visualContainer">
                                    <ModelVisual3D.Content>
                                        <Model3DGroup x:Name="modelGroupMassimizzato" />
                                    </ModelVisual3D.Content>
                                </ModelVisual3D>
                            </helix:HelixViewport3D>

                            <Button Content="{DynamicResource StrTornaGalleria}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15" Padding="15,8" Click="BtnTornaGalleria_Click" Style="{StaticResource BaseCardButtonStyle}" Background="{DynamicResource BgCard}" Foreground="White"/>
                        </Grid>

                    </Grid>
                </Border>

                <GridSplitter Grid.Column="3" Style="{StaticResource ModernGridSplitterStyle}" Margin="0,0,0,10" VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

                <Border Grid.Column="4" Background="{DynamicResource BgCard}" Margin="4,0,10,10" CornerRadius="8" Effect="{StaticResource OmbraCard}">
                    <DockPanel>
                        <Border DockPanel.Dock="Bottom" Background="{DynamicResource BgFinestra}" CornerRadius="6" Padding="5" Margin="15,0,15,15">
                            <StackPanel x:Name="pannelloSfondo" Margin="10">
                                <TextBlock Text="{DynamicResource StrSfondoVisual}" Foreground="{DynamicResource TestoSecondario}" Margin="0,0,0,8" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <Button x:Name="btnSfondoColore" Content="{DynamicResource StrCambiaSfondo}" Margin="0" Style="{StaticResource BaseCardButtonStyle}" Click="BtnSfondoColore_Click" Foreground="{DynamicResource TestoPrincipale}" Background="{DynamicResource BgPulsante}" Padding="10"/>
                            </StackPanel>
                        </Border>

                        <StackPanel x:Name="pannelloProprieta" Margin="15,15,15,0" IsEnabled="False">
                            <TextBlock Text="{DynamicResource StrProprieta}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TestoPrincipale}" Margin="0,0,0,5" TextAlignment="Center"/>
                            <TextBlock x:Name="txtNomeSelezionato" Text="{DynamicResource StrNessunaSelezione}" Foreground="{DynamicResource ColorePrimario}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,20" TextAlignment="Center"/>

                            <CheckBox x:Name="chkApplicaATutti" Content="{DynamicResource StrApplicaTutti}" Style="{StaticResource ModernToggleStyle}" Margin="0,5,0,15" IsChecked="True" FontSize="14" Cursor="Hand"/>

                            <TextBlock Text="{DynamicResource StrColore}" Foreground="{DynamicResource TestoSecondario}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <Border Background="{DynamicResource BgFinestra}" CornerRadius="6" Padding="8" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="rectColore" Background="White" CornerRadius="4" Margin="0,0,10,0" BorderBrush="{DynamicResource ColoreBordoCard}" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="RectColore_Click"/>
                                    <Button Content="{DynamicResource StrModifica}" Grid.Column="1" Style="{StaticResource BaseCardButtonStyle}" Background="{DynamicResource BgPulsante}" Foreground="{DynamicResource TestoPrincipale}" Padding="10,5" Click="RectColore_Click"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="{DynamicResource StrImgTexture}" Foreground="{DynamicResource TestoSecondario}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <Border Background="{DynamicResource BgFinestra}" CornerRadius="6" Padding="8">
                                <StackPanel>
                                    <TextBlock x:Name="txtTexturePath" Text="{DynamicResource StrNessuna}" Foreground="{DynamicResource TestoPrincipale}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <Grid Margin="0,0,0,25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="{DynamicResource StrSfoglia}" Style="{StaticResource BaseCardButtonStyle}" Background="{DynamicResource BgPulsante}" Foreground="{DynamicResource TestoPrincipale}" Padding="10,8" Margin="0,0,5,0" Click="BtnSkin_Click"/>
                                        <Button Content="{DynamicResource StrRimuovi}" Grid.Column="1" Style="{StaticResource BaseCardButtonStyle}" Background="#FFD32F2F" Foreground="White" Padding="10,8" Margin="5,0,0,0" Click="BtnRemoveSkin_Click"/>
                                    </Grid>

                                    <TextBlock Text="{DynamicResource StrZoomSkin}" Foreground="{DynamicResource TestoSecondario}" Margin="0,0,0,5" FontWeight="SemiBold" FontSize="11"/>

                                    <Grid Margin="0,0,0,25" PreviewMouseDown="Zoom_PreviewMouseDown">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="45"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="slZoomSkin" Style="{StaticResource ModernSliderStyle}" Minimum="0.01" Maximum="30" Value="1" TickFrequency="0.1" ValueChanged="SlZoomSkin_ValueChanged" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox x:Name="txtZoomSkin" Text="1.00" Style="{StaticResource ModernInputStyle}" Grid.Column="1" TextChanged="TxtZoomSkin_TextChanged"/>
                                    </Grid>

                                    <Button x:Name="btnAutoFit" Content="{DynamicResource StrAdattaImg}" Style="{StaticResource BaseCardButtonStyle}" Background="{DynamicResource ColoreSecondario}" Foreground="White" Padding="15,10" Click="BtnAutoFitSkin_Click" UseLayoutRounding="False"/>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="txtStatus" Margin="0,20" TextWrapping="Wrap" Foreground="{DynamicResource ColoreIngressi}" FontWeight="SemiBold" TextAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</Window>