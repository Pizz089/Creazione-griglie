<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BgFinestra" Color="#FF2A2E38"/>
    <SolidColorBrush x:Key="BgCard" Color="#FF3A414F"/>

    <SolidColorBrush x:Key="TestoPrincipale" Color="#FFEEEEEE"/>
    <SolidColorBrush x:Key="TestoSecondario" Color="#FFB2BDC8"/>
    <SolidColorBrush x:Key="TestoSecondarioOnLight" Color="#FF757575"/>

    <SolidColorBrush x:Key="BgAppBar" Color="#FF1976D2"/>
    <SolidColorBrush x:Key="ColorePrimario" Color="#FF1E88E5"/>
    <SolidColorBrush x:Key="ColoreSecondario" Color="#FF708090"/>

    <SolidColorBrush x:Key="BgCardHover" Color="#FF4A5364"/>
    <SolidColorBrush x:Key="ColoreSelezione" Color="#FF1E3A5F"/>
    <SolidColorBrush x:Key="ColoreBordoCard" Color="#FF4F586D"/>

    <SolidColorBrush x:Key="ColoreIngressi" Color="#FF81C784"/>
    <SolidColorBrush x:Key="ColoreUscite" Color="#FFFFB74D"/>
    <SolidColorBrush x:Key="ColoreAllarme" Color="#FFE57373"/>

    <DropShadowEffect x:Key="OmbraCard" Color="Black" Opacity="0.40" BlurRadius="15" ShadowDepth="3" Direction="270"/>
    <DropShadowEffect x:Key="OmbraPopUp" Color="Black" Opacity="0.60" BlurRadius="30" ShadowDepth="6" Direction="270"/>

    <SolidColorBrush x:Key="BgPulsante" Color="#FF4F586D"/>
    <SolidColorBrush x:Key="BordoPulsante" Color="#FF67728A"/>
    <SolidColorBrush x:Key="BgPulsantePressed" Color="#FF3A414F"/>
    <SolidColorBrush x:Key="ColorePrimarioAlpha" Color="#202196F3"/>
</ResourceDictionary>