<Window x:Class="DirectXEditor.ModernColorPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Material Editor Avanzato" Height="680" Width="850"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow" ResizeMode="NoResize"
        Background="{DynamicResource BgFinestra}">

    <Window.Resources>
        <Style x:Key="ModernInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FF1E222B"/>
            <Setter Property="Foreground" Value="{DynamicResource TestoPrincipale}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FF3A414F"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource ColorePrimario}"/>
                    <Setter Property="Background" Value="#FF2A2E38"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Padding="20" Background="{DynamicResource BgCard}" Margin="10" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Proprietà Materiale" Foreground="{DynamicResource TestoPrincipale}" FontWeight="Bold" FontSize="18" Margin="0,0,0,10" TextAlignment="Center"/>

                <UniformGrid Columns="3" Margin="0,0,0,10">
                    <RadioButton x:Name="radDiffuse" Content="Diffuse (Base)" Style="{StaticResource TabToggleStyle}" IsChecked="True" Checked="Canale_Changed"/>
                    <RadioButton x:Name="radSpecular" Content="Specular (Luce)" Style="{StaticResource TabToggleStyle}" Margin="5,0" Checked="Canale_Changed"/>
                    <RadioButton x:Name="radEmissive" Content="Emissive (Glow)" Style="{StaticResource TabToggleStyle}" Checked="Canale_Changed"/>
                </UniformGrid>

                <Border Height="50" CornerRadius="8" Margin="0,0,0,15">
                    <Border.Background>
                        <DrawingBrush Viewport="0,0,10,10" ViewportUnits="Absolute" TileMode="Tile">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#FF2A2E38">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,10,10"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing Brush="#FF3A414F">
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <RectangleGeometry Rect="0,0,5,5"/>
                                                <RectangleGeometry Rect="5,5,5,5"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Border.Background>
                    <Border x:Name="ColorPreview" Background="White" CornerRadius="8"/>
                </Border>

                <Border Background="#FF2A2E38" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="45"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="R (Rosso)" Foreground="#FFEF9A9A" FontWeight="Bold" VerticalAlignment="Center" Grid.Row="0"/>
                        <Slider x:Name="slR" Maximum="255" Style="{StaticResource ModernSliderStyle}" ValueChanged="Slider_ValueChanged" Grid.Row="0" Grid.Column="1" Margin="5,0"/>
                        <TextBox x:Name="txtR" Text="255" Style="{StaticResource ModernInputStyle}" Grid.Row="0" Grid.Column="2" TextChanged="Txt_TextChanged"/>

                        <TextBlock Text="G (Verde)" Foreground="#FFA5D6A7" FontWeight="Bold" VerticalAlignment="Center" Grid.Row="1" Margin="0,15,0,0"/>
                        <Slider x:Name="slG" Maximum="255" Style="{StaticResource ModernSliderStyle}" ValueChanged="Slider_ValueChanged" Grid.Row="1" Grid.Column="1" Margin="5,15,5,0"/>
                        <TextBox x:Name="txtG" Text="255" Style="{StaticResource ModernInputStyle}" Grid.Row="1" Grid.Column="2" Margin="0,15,0,0" TextChanged="Txt_TextChanged"/>

                        <TextBlock Text="B (Blu)" Foreground="#FF90CAF9" FontWeight="Bold" VerticalAlignment="Center" Grid.Row="2" Margin="0,15,0,0"/>
                        <Slider x:Name="slB" Maximum="255" Style="{StaticResource ModernSliderStyle}" ValueChanged="Slider_ValueChanged" Grid.Row="2" Grid.Column="1" Margin="5,15,5,0"/>
                        <TextBox x:Name="txtB" Text="255" Style="{StaticResource ModernInputStyle}" Grid.Row="2" Grid.Column="2" Margin="0,15,0,0" TextChanged="Txt_TextChanged"/>

                        <Border Grid.Row="3" Grid.ColumnSpan="3" Height="1" Background="#FF3A414F" Margin="0,15,0,10"/>

                        <TextBlock x:Name="lblAlpha" Text="A (Transp)" Foreground="#FFD1C4E9" FontWeight="Bold" VerticalAlignment="Center" Grid.Row="4"/>
                        <Slider x:Name="slA" Maximum="255" Style="{StaticResource ModernSliderStyle}" ValueChanged="Slider_ValueChanged" Grid.Row="4" Grid.Column="1" Margin="5,0"/>
                        <TextBox x:Name="txtA" Text="255" Style="{StaticResource ModernInputStyle}" Grid.Row="4" Grid.Column="2" TextChanged="Txt_TextChanged"/>
                    </Grid>
                </Border>

                <Border Background="#FF2A2E38" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="45"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Power (Luce)" Foreground="#FFFFCC80" FontWeight="Bold" VerticalAlignment="Center" ToolTip="Concentrazione del riflesso"/>
                        <Slider x:Name="slPower" Maximum="100" Style="{StaticResource ModernSliderStyle}" ValueChanged="Slider_ValueChanged" Grid.Column="1" Margin="5,0"/>
                        <TextBox x:Name="txtPower" Text="0" Style="{StaticResource ModernInputStyle}" Grid.Column="2" TextChanged="Txt_TextChanged"/>
                    </Grid>
                </Border>

                <TextBlock Text="Colori Predefiniti" Foreground="{DynamicResource TestoSecondario}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5"/>
                <ItemsControl ItemsSource="{Binding ListaPredefiniti}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource SwatchStyle}" Background="{Binding}" Click="Swatch_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Recenti" Foreground="{DynamicResource TestoSecondario}" FontWeight="SemiBold" FontSize="11" Margin="0,10,0,5"/>
                <ItemsControl ItemsSource="{Binding ListaRecenti}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource SwatchStyle}" Background="{Binding}" Click="Swatch_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Margin="0,10,10,10" Background="#0A0B0E" CornerRadius="8" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Viewport3D x:Name="vpFront" Grid.Row="0" Grid.Column="0" Margin="2">
                    <Viewport3D.Camera>
                        <PerspectiveCamera Position="0,0,3" LookDirection="0,0,-3" UpDirection="0,1,0" FieldOfView="45"/>
                    </Viewport3D.Camera>
                    <ModelVisual3D x:Name="mvFront"/>
                </Viewport3D>
                <TextBlock Text="Normale (Frontale)" Foreground="#555" Margin="10" Grid.Row="0" Grid.Column="0" IsHitTestVisible="False"/>

                <Viewport3D x:Name="vpIso" Grid.Row="0" Grid.Column="1" Margin="2">
                    <Viewport3D.Camera>
                        <PerspectiveCamera Position="2,2,2" LookDirection="-2,-2,-2" UpDirection="0,1,0" FieldOfView="45"/>
                    </Viewport3D.Camera>
                    <ModelVisual3D x:Name="mvIso"/>
                </Viewport3D>
                <TextBlock Text="Isometrica" Foreground="#555" Margin="10" Grid.Row="0" Grid.Column="1" IsHitTestVisible="False"/>

                <Viewport3D x:Name="vpIsoUp" Grid.Row="1" Grid.Column="0" Margin="2">
                    <Viewport3D.Camera>
                        <PerspectiveCamera Position="1.5,-2.5,1.5" LookDirection="-1.5,2.5,-1.5" UpDirection="0,1,0" FieldOfView="45"/>
                    </Viewport3D.Camera>
                    <ModelVisual3D x:Name="mvIsoUp"/>
                </Viewport3D>
                <TextBlock Text="Rivolta verso l'alto" Foreground="#555" Margin="10" Grid.Row="1" Grid.Column="0" IsHitTestVisible="False"/>

                <Viewport3D x:Name="vp45" Grid.Row="1" Grid.Column="1" Margin="2">
                    <Viewport3D.Camera>
                        <PerspectiveCamera Position="2.5,0,2.5" LookDirection="-2.5,0,-2.5" UpDirection="0,1,0" FieldOfView="45"/>
                    </Viewport3D.Camera>
                    <ModelVisual3D x:Name="mv45"/>
                </Viewport3D>
                <TextBlock Text="Angolo a 45°" Foreground="#555" Margin="10" Grid.Row="1" Grid.Column="1" IsHitTestVisible="False"/>

                <Border Grid.RowSpan="2" Grid.Column="0" BorderBrush="#1E222B" BorderThickness="0,0,2,0"/>
                <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="#1E222B" BorderThickness="0,0,0,2"/>
            </Grid>
        </Border>

        <Button Content="Applica Modifiche" Background="{DynamicResource ColorePrimario}" Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Click="BtnOk_Click" Grid.Row="1" Margin="5,5,5,5" Width="360" HorizontalAlignment="Center" Height="40" Grid.ColumnSpan="2">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>