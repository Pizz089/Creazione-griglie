<Window x:Class="Creazione_griglie.FlatColorPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource StrTitoloSfondo}" Height="480" Width="550"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow" ResizeMode="NoResize"
        Background="{DynamicResource BgFinestra}">

    <Grid Margin="5,15,5,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="220"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="rectPreview" Grid.Row="0" CornerRadius="8" Margin="10,10,10,10" 
                BorderBrush="{DynamicResource ColoreBordoCard}" BorderThickness="1" Grid.Column="1">
            <Border.Background>
                <SolidColorBrush Color="#FF1E222B"/>
            </Border.Background>
        </Border>

        <Border Background="{DynamicResource BgCardHover}" CornerRadius="8" Padding="15" Margin="10,10,10,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{DynamicResource StrRosso}" Foreground="#FFEF9A9A" FontWeight="Bold" VerticalAlignment="Center" Grid.Row="0"/>
                <Slider x:Name="slR" Maximum="255" Style="{StaticResource ModernSliderStyle}" ValueChanged="Slider_ValueChanged" Grid.Row="0" Grid.Column="1" Margin="5,10,5,10"/>
                <TextBox x:Name="txtR" Text="255" Style="{StaticResource ModernInputStyle}" Grid.Row="0" Grid.Column="2" TextChanged="Txt_TextChanged" VerticalAlignment="Center"/>

                <TextBlock Text="{DynamicResource StrVerde}" Foreground="#FFA5D6A7" FontWeight="Bold" VerticalAlignment="Center" Grid.Row="1" Margin="0,15,0,0"/>
                <Slider x:Name="slG" Maximum="255" Style="{StaticResource ModernSliderStyle}" ValueChanged="Slider_ValueChanged" Grid.Row="1" Grid.Column="1" Margin="5,10,5,10"/>
                <TextBox x:Name="txtG" Text="255" Style="{StaticResource ModernInputStyle}" Grid.Row="1" Grid.Column="2" Margin="0,15,0,0" TextChanged="Txt_TextChanged" VerticalAlignment="Center"/>

                <TextBlock Text="{DynamicResource StrBlu}" Foreground="#FF90CAF9" FontWeight="Bold" VerticalAlignment="Center" Grid.Row="2" Margin="0,15,0,0"/>
                <Slider x:Name="slB" Maximum="255" Style="{StaticResource ModernSliderStyle}" ValueChanged="Slider_ValueChanged" Grid.Row="2" Grid.Column="1" Margin="5,10,5,10"/>
                <TextBox x:Name="txtB" Text="255" Style="{StaticResource ModernInputStyle}" Grid.Row="2" Grid.Column="2" Margin="0,15,0,0" TextChanged="Txt_TextChanged" VerticalAlignment="Center"/>

                <Border Grid.Row="3" Grid.ColumnSpan="3" Height="1" Background="#FF3A414F" Margin="0,15,0,10"/>

                <TextBlock x:Name="lblAlpha" Text="{DynamicResource StrTrasparenza}" Foreground="#FFD1C4E9" FontWeight="Bold" VerticalAlignment="Center" Grid.Row="4"/>
                <Slider x:Name="slA" Maximum="255" Style="{StaticResource ModernSliderStyle}" ValueChanged="Slider_ValueChanged" Grid.Row="4" Grid.Column="1" Margin="5,10,5,10"/>
                <TextBox x:Name="txtA" Text="255" Style="{StaticResource ModernInputStyle}" Grid.Row="4" Grid.Column="2" TextChanged="Txt_TextChanged" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource BgCardHover}" CornerRadius="8" Padding="10,10,10,10" Margin="5,5,5,10">
                <StackPanel>
                    <TextBlock Text="{DynamicResource StrColoriPredefiniti}" Foreground="{DynamicResource TestoSecondario}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5"/>
                    <ItemsControl ItemsSource="{Binding ListaPredefiniti}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SwatchStyle}" Background="{Binding}" Click="Swatch_Click"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource BgCardHover}" CornerRadius="8" Padding="10,10,10,10" Margin="5,5,5,10" Grid.Column="1">
                <StackPanel>
                    <TextBlock Text="{DynamicResource StrRecenti}" Foreground="{DynamicResource TestoSecondario}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5"/>
                    <ItemsControl ItemsSource="{Binding ListaRecenti}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SwatchStyle}" Background="{Binding}" Click="Swatch_Click"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <Button Grid.Row="2" Content="{DynamicResource StrApplicaSfondo}" 
                Background="{DynamicResource ColorePrimario}" Foreground="White" FontWeight="Bold" FontSize="14"
                Padding="10,12" Cursor="Hand" BorderThickness="0" Click="BtnOk_Click" Style="{StaticResource BaseCardButtonStyle}" Width="260" Grid.ColumnSpan="2"/>
    </Grid>
</Window>